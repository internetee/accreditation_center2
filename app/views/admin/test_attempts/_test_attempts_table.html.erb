<table>
  <tr>
    <td>
      <%= sanitize pagy_info(@pagy, item_name: t('.items', count: @pagy.count)) %>
    </td>
  </tr>
</table>
<table class="table">
  <thead>
    <tr>
      <th><%= sort_link(@search, 'user_name', t('.user')) %></th>
      <th><%= sort_link(@search, 'started_at', t('.started_at')) %></th>
      <th><%= sort_link(@search, 'completed_at', t('.completed_at')) %></th>
      <th><%= sort_link(@search, 'duration', t('.duration')) %></th>
      <th><%= sort_link(@search, 'score_percentage', t('.score')) %></th>
      <th><%= sort_link(@search, 'status', t('.status')) %></th>
      <th class="table--action"></th>
    </tr>
  </thead>
  <tbody>
    <% @test_attempts.each do |attempt| %>
      <tr>
        <td>
          <%= link_to attempt.user.display_name, admin_user_path(attempt.user) %>
        </td>
        <td><%= l(attempt.started_at, format: :short) if attempt.started_at %></td>
        <td><%= l(attempt.completed_at, format: :short) if attempt.completed_at %></td>
        <td>
          <%= render partial: 'admin/test_attempts/duration', locals: { attempt: attempt } %>
        </td>
        <td>
          <span class="score-value"><%= number_to_percentage(attempt.score_percentage, precision: 1) %></span>
        </td>
        <td>
          <% if attempt.passed? %>
            <span class="label label-success"><%= t('admin.test_attempts.show.passed') %></span>
          <% elsif attempt.failed? %>
            <span class="label label-danger"><%= t('admin.test_attempts.show.failed') %></span>
          <% elsif attempt.not_started? %>
            <span class="label label-warning"><%= t('admin.test_attempts.show.not_started') %></span>
          <% elsif attempt.time_expired? && !attempt.completed? %>
            <span class="label label-danger"><%= t('admin.test_attempts.show.time_expired') %></span>
          <% else %>
            <span class="label label-warning"><%= t('admin.test_attempts.show.in_progress') %></span>
          <% end %>
        </td>
        <td class="table--action">
          <% if attempt.failed? || attempt.time_expired? %>
            <%= icon_link_to 'fas fa-trash-alt', admin_test_test_attempt_path(@test, attempt), 
                class: 'simple_tooltip', 
                data: { 'tippy-content': t('.remove_assignment'), turbo: true, turbo_method: :delete, turbo_confirm: t('.confirm_remove_assignment') } %>
          <% end %>
          
          <% if attempt.in_progress? && !attempt.time_expired? %>
            <%= icon_link_to 'fas fa-clock', extend_time_admin_test_test_attempt_path(@test, attempt), 
                class: 'simple_tooltip', 
                data: { 'tippy-content': t('.extend_time'), turbo: true, turbo_method: :patch, turbo_confirm: t('.confirm_extend_time') } %>
          <% end %>
          <%= icon_link_to 'fas fa-eye', admin_test_test_attempt_path(@test, attempt), 
            class: 'simple_tooltip', 
            data: { 'tippy-content': t('.view_attempt'), turbo: false } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>