<% content_for(:title) { "EIS | #{t('.page_title', practical_task: @practical_task.title)}" } %>
<% content_for :hero do %>
    <div class="layout--hero">
        <h1><%= @practical_task.title %></h1>
        <div class="monospace"><%= @practical_task_result.test_attempt.access_code %></div>
        <%= back_link(text: t('.back_to_results'), path: admin_test_practical_task_practical_task_results_path(@test, @practical_task)) %>
    </div>
<% end %>

<div class="page page--admin-practical-task-result-show">
  <div class="page--header">
    <div class="wrapper">
      <div class="row center-xs">
      </div>
    </div>
  </div>

  <% feedback_locked = @test_attempt.completed? %>
  <div class="wrapper">
    <div class="row">
      <div class="col-md-6 col-xs-12">
        <div class="paper">
          <div class="paper--header">
            <h3><%= t('.result_information') %></h3>
          </div>
          
          <div class="paper--content">
            <div class="summary-stats">
              <div class="stat-item">
                <span class="stat-label"><%= t('.user') %>:</span>
                <span class="stat-value"><%= link_to @user.display_name, admin_user_path(@user) %></span>
              </div>
              <div class="stat-item">
                <span class="stat-label"><%= t('.test_attempt') %>:</span>
                <span class="stat-value"><%= link_to @test_attempt.access_code, admin_test_test_attempt_path(@test, @test_attempt) %></span>
              </div>
              <div class="stat-item">
                <span class="stat-label "><%= t('.submitted_at') %>:</span>
                <span class="stat-value"><%= @practical_task_result.created_at.strftime('%Y-%m-%d %H:%M:%S') %></span>
              </div>
              <div class="stat-item">
                <span class="stat-label"><%= t('.validated_at') %>:</span>
                <span class="stat-value">
                  <%= @practical_task_result.validated_at&.strftime('%Y-%m-%d %H:%M:%S') || t('.not_validated_yet') %>
                </span>
              </div>
              <div class="stat-item">
                <span class="stat-label"><%= t('.status') %>:</span>
                <span class="stat-value">
                  <%= practical_task_result_status_badge(
                    @practical_task_result.status,
                    t(".#{@practical_task_result.status}")
                  ) %>
                </span>
              </div>
              <% if @practical_task_result.feedback.present? %>
                <div class="stat-item">
                  <span class="stat-label"><%= t('.feedback_by') %>:</span>
                  <span class="stat-value">
                    <%= @practical_task_result.feedback_by_name.presence || t('.unknown_admin') %>
                  </span>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    
      <div class="col-md-6 col-xs-12">
        <div class="paper">
          <div class="paper--header">
            <h3><%= t('.admin_actions') %></h3>
          </div>
          
          <div class="paper--content">
            <%= form_with model: [:admin, @test, @practical_task, @practical_task_result], local: true, class: 'form' do |form| %>
              <div class="form--row">
                <%= form.label :status, t('.status'), class: 'form--label' %>
                <div class="form--field">
                  <div class="form--input">
                    <%= simple_select_tag 'practical_task_result[status]', 
                      options_for_select([
                        [t('.pending'), 'pending'],
                        [t('.running'), 'running'],
                        [t('.passed'), 'passed'],
                        [t('.failed'), 'failed']
                      ], @practical_task_result.status), 
                      { required: true, disabled: feedback_locked } %>
                  </div>
                </div>
              </div>

              <div class="form--row">
                <%= form.label :feedback, t('.feedback'), class: 'form--label' %>
                <div class="form--field">
                  <div class="form--input">
                    <%= form.text_area :feedback, class: 'textarea', rows: 4, disabled: feedback_locked %>
                    <% if feedback_locked %>
                      <small><%= t('.feedback_locked_after_completion') %></small>
                    <% end %>
                  </div>
                </div>
              </div>

              <div class="form--actions">
                <%= form.submit t(:save), class: 'button button--primary', disabled: feedback_locked %>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <% if @practical_task_result.inputs.present? %>
        <div class="col-md-12 col-xs-12">
          <div class="paper">
            <div class="paper--header">
              <h3><%= t('.inputs') %></h3>
            </div>
            <div class="paper--content">
              <div class="coderay">
                <%= CodeRay.scan(JSON.pretty_generate(@practical_task_result.inputs), :json).div().html_safe %>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <% if @practical_task_result.result.present? %>
          <div class="col-md-12 col-xs-12">
            <div class="paper">
              <div class="paper--header">
                <h3><%= t('.result') %></h3>
              </div>
              
              <div class="paper--content">
                <div class="coderay">
                  <%= CodeRay.scan(JSON.pretty_generate(@practical_task_result.result), :json).div().html_safe %>
                </div>
              </div>
            </div>
          </div>
      <% end %>

    </div>
  </div>
</div>
