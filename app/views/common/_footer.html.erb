<footer class="layout--footer">
    <div class="layout--footer-top">
        <a class="layout--footer-logo" href="https://internet.ee">
            <img src="/eis-logo-white.svg" alt="Eesti Interneti SA">
        </a>
        <div class="layout--footer-contacts">
            <div class="address">
                <h3><%= t('.copyright', year: Date.current.year) %></h3>
                <p><%= t('.address') %></p>
                <p><%= t('.registration_code') %></p>
            </div>
            <ul class="quickinfo">
                <li><i aria-hidden="true" class="fas fa-envelope"></i><a href="mailto:info@internet.ee">info@internet.ee</a></li>
                <li><i aria-hidden="true" class="fas fa-phone"></i>727 1000</li>
            </ul>
        </div>
    </div>
    <div class="layout--footer-bottom">
        <nav class="menu--footer">
            <div class="column">
                <h3><%= t('.help_and_info') %></h3>
                <ul>
                    <li><a title="<%= t('.links.domain_regulation') %>" href="<%= t('.links.domain_regulation') %>" target="_blank"><%= t('.domain_regulation') %></a></li>
                    <li><a title="<%= t('.links.faq') %>" href="<%= t('.links.faq') %>" target="_blank"><%= t('.faq') %></a></li>
                    <li><a title="<%= t('.links.statistics') %>" href="<%= t('.links.statistics') %>" target="_blank"><%= t('.statistics') %></a></li>
                    <li><a title="<%= t('.links.dispute_committee') %>" href="<%= t('.links.dispute_committee') %>" target="_blank"><%= t('.dispute_committee') %></a></li>
                    <li><a href="javascript:void(0)" title="Cookie Settings" data-cc="show-preferencesModal" aria-haspopup="dialog"><%= t('.cookie_settings') %></a></li>
                </ul>
            </div>
            <div class="column">
                <h3><%= t('.registrars') %></h3>
                <ul>
                    <li><a title="<%= t('.links.list_of_accredited_registrars') %>" href="<%= t('.links.list_of_accredited_registrars') %>" target="_blank"><%= t('.list_of_accredited_registrars') %></a></li>
                    <li><a title="<%= t('.links.terms_and_conditions_for_registrars') %>" href="<%= t('.links.terms_and_conditions_for_registrars') %>" target="_blank"><%= t('.terms_and_conditions_for_registrars') %></a></li>
                    <li><a title="<%= t('.links.partner_programme') %>" href="<%= t('.links.partner_programme') %>" target="_blank"><%= t('.partner_programme') %></a></li>
                </ul>
            </div>
            <div class="column">
                <h3><%= t('.estonian_internet') %></h3>
                <ul>
                    <li><a title="<%= t('.links.contact_us') %>" href="<%= t('.links.contact_us') %>" target="_blank"><%= t('.contact_us') %></a></li>
                    <li><a title="<%= t('.links.management') %>" href="<%= t('.links.management') %>" target="_blank"><%= t('.management') %></a></li>
                    <li><a title="<%= t('.links.documents') %>" href="<%= t('.links.documents') %>" target="_blank"><%= t('.documents') %></a></li>
                </ul>
            </div>
        </nav>
        <nav class="menu--social">
            <h3><%= t('.social_media') %></h3>
            <ul>
                <li><a href="https://www.facebook.com/EE-748656818569233/" title="Facebook"><i aria-hidden="true" class="fab fa-facebook-square"></i></a></li>
                <li><a href="https://twitter.com/Eesti_Internet" title="Twitter"><i aria-hidden="true" class="fab fa-twitter"></i></a></li>
                <li><a href="https://www.youtube.com/channel/UC7nTB6zIwZYPFarlbKuEPRA" title="Youtube"><i aria-hidden="true" class="fab fa-youtube-square"></i></a></li>
                <li><a href="https://internet.ee/index.rss" title="RSS"><i aria-hidden="true" class="fas fa-rss-square"></i></a></li>
            </ul>
        </nav>
    </div>
</footer>
<script crossorigin="anonymous" src="https://polyfill-fastly.io/v3/polyfill.min.js?features=Array.from%2CArray.prototype.find%2CArray.prototype.includes%2CSymbol%2CSymbol.iterator%2CDOMTokenList%2CObject.assign%2CCustomEvent%2CElement.prototype.classList%2CElement.prototype.closest%2CElement.prototype.dataset"></script>
