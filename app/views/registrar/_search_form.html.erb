<%= form_with url: registrar_path, method: :get, local: true, data: { turbo: false } do %>
  <% if params[:sort].present? %>
    <%= hidden_field_tag :sort, params[:sort] %>
    <%= hidden_field_tag :direction, (params[:direction].presence_in(%w[asc desc]) || 'asc') %>
  <% end %>
  <div class="row">
    <div class="col-md-5 col-md-offset-4 col-xs">
      <div class="form--field">
        <div class="form--input large">
          <%= text_field_tag(
                :q,
                params[:q],
                class: 'input search',
                placeholder: t('registrar.show.search_placeholder'),
                'aria-label': t('registrar.show.search_aria_label')
              ) %>
          <%= button_tag(type: 'submit', class: 'button button--primary', 'aria-label': t(:search)) do %>
            <i class="fas fa-arrow-right"></i>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
