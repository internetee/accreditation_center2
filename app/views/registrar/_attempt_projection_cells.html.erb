<% attempt = projection[:latest_attempt] %>
<% result = projection[:result] %>
<td><%= attempt&.test&.title.presence || t('registrar.show.not_applicable') %></td>
<td>
  <% case result
     when :in_progress %>
    <%= t('registrar.show.workflow_in_progress') %>
  <% when :passed, :failed, :time_expired %>
    <%= t('registrar.show.workflow_completed') %>
  <% else %>
    <%= t('registrar.show.workflow_not_started') %>
  <% end %>
</td>
<td>
  <% if result == :passed %>
    <span class="badge badge-success"><%= t('admin.test_attempts.test_attempts_table.passed') %></span>
  <% elsif result == :failed %>
    <span class="badge badge-danger"><%= t('admin.test_attempts.test_attempts_table.failed') %></span>
  <% elsif result == :time_expired %>
    <span class="badge badge-danger"><%= t('admin.test_attempts.test_attempts_table.time_expired') %></span>
  <% elsif result == :in_progress %>
    <span class="badge badge-warning"><%= t('admin.test_attempts.test_attempts_table.in_progress') %></span>
  <% else %>
    <span class="badge badge-default"><%= t('admin.test_attempts.test_attempts_table.not_started') %></span>
  <% end %>
</td>
<td>
  <% if projection[:completed_at].present? %>
    <%= l(projection[:completed_at], format: :short) %>
  <% else %>
    <%= t('registrar.show.not_applicable') %>
  <% end %>
</td>
